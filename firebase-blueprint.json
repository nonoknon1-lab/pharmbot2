{
  "entities": {
    "Guideline": {
      "title": "Guideline",
      "description": "A pharmaceutical guideline or reference document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "pdf", "link", "image"] },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "type", "content", "date"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/guidelines/{guidelineId}": {
      "schema": "Guideline",
      "description": "A collection of guidelines for a specific user."
    },
    "/global_guidelines/{guidelineId}": {
      "schema": "Guideline",
      "description": "A collection of shared guidelines accessible to everyone."
    }
  }
}
